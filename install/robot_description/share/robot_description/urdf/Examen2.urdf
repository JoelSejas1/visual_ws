<robot name="humanoid_planar_arm">

    <link name="link0_passive">
        <visual>
            <geometry><cylinder length="0.1" radius="0.3"/></geometry>
            <material name="blue"><color rgba="0 0 0.8 1"/></material>
        </visual>
    </link>

    <joint name="q1" type="revolute">
        <origin xyz="0 0 0.05" rpy="0 0 0"/>
        <parent link="link0_passive"/>
        <child link="link1"/>
        <axis xyz="0 0 1"/>
        <limit lower="0.0" upper="3.1416" effort="50" velocity="1.5"/>
    </joint>

    <link name="link1">
        <visual>
            <origin xyz="5 0 0" rpy="0 1.571 0"/>
            <geometry><cylinder length="10.0" radius="0.1"/></geometry>
            <material name="red"><color rgba="0.8 0 0 1"/></material>
        </visual>
    </link>

    <joint name="q2" type="revolute">
        <origin xyz="10 0 0" rpy="0 0 0"/>
        <parent link="link1"/>
        <child link="link2"/>
        <axis xyz="0 0 1"/>
        <limit lower="0.0" upper="2.618" effort="40" velocity="2.0"/>
    </joint>

    <link name="link2">
        <visual>
            <origin xyz="3 0 0" rpy="0 1.571 0"/>
            <geometry><cylinder length="6.0" radius="0.1"/></geometry>
            <material name="blue"/>
        </visual>
    </link>

    <joint name="q3" type="revolute">
        <origin xyz="6 0 0" rpy="0 0 0"/>
        <parent link="link2"/>
        <child link="link3"/>
        <axis xyz="0 0 1"/>
        <limit lower="-1.2217" upper="1.2217" effort="20" velocity="3.0"/>
    </joint>

    <link name="link3">
        <visual>
            <origin xyz="2 0 0" rpy="0 1.571 0"/>
            <geometry><cylinder length="4.0" radius="0.1"/></geometry>
            <material name="red"/>
        </visual>
    </link>

    <joint name="q4" type="revolute">
        <origin xyz="4 0 0" rpy="0 0 0"/>
        <parent link="link3"/>
        <child link="link4"/>
        <axis xyz="0 0 1"/>
        <limit lower="0.0" upper="1.571" effort="10" velocity="3.0"/>
    </joint>

    <link name="link4">
        <visual>
            <origin xyz="1.5 0 0" rpy="0 1.571 0"/>
            <geometry><cylinder length="3.0" radius="0.1"/></geometry>
            <material name="blue"/>
        </visual>
    </link>

</robot>